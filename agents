#!/usr/bin/env bash
# agents -- launch the Textual "agents tui" dashboard over ~20 Claude Code
# tmux sessions. Replaces the fzf cockpit (preserved as `agents-classic`).
#
# Runs entirely inside the isolated venv in this dir (only dep: textual).
# tmux owns the truth (sessions, identity stamps, attention tint, aerospace
# wid); /tmp/claude-ctx supplies ctx%; ~/.claude/projects/*.jsonl transcripts
# supply the last message + age. Enter jumps to the Ghostty window via
# Aerospace (@aerospace_wid).
#
# The previous fzf picker still lives next to this file as `agents-classic`
# (and is symlinked at ~/.local/bin/agents-classic).

set -euo pipefail

HERE="/Users/kiran/Desktop/forge.nosync/agents-cockpit"
VENV_PY="${HERE}/.venv/bin/python"

if [ ! -x "$VENV_PY" ]; then
  echo "agents: venv python not found at $VENV_PY" >&2
  echo "  recreate it: /opt/homebrew/bin/python3 -m venv ${HERE}/.venv && ${HERE}/.venv/bin/pip install -r ${HERE}/requirements.txt" >&2
  exit 1
fi

# Give THIS Ghostty window a stable, unique title so AeroSpace can single it
# out (Textual never emits an OS window-title escape, so we do it here via
# OSC-2). Then put the cockpit on its own workspace D: the on-window-detected
# rule catches a freshly-spawned cockpit window, and for the common in-place
# launch we also move THIS window to D and follow it there. All best-effort.
printf '\033]2;Agent Cockpit\007'
if command -v aerospace >/dev/null 2>&1; then
  aerospace move-node-to-workspace D >/dev/null 2>&1 || true
  aerospace workspace D              >/dev/null 2>&1 || true
fi

# Best-effort: ensure the ctx-monitor sidecar is running (it feeds the cockpit's
# Context tab + drives the checkpoint cycle). Spawn it DETACHED so it survives
# the cockpit closing. NEVER block or fail the cockpit launch — the whole block
# is wrapped so any error is swallowed. ctx-monitor is pure stdlib, so we use
# SYSTEM python3 (NOT the cockpit venv). The monitor's own flock makes a
# redundant spawn a harmless no-op, so "spawn if the lock-PID isn't alive" is
# safe even against races.
{
  CTX_DIR="/tmp/claude-ctx"
  MON="${HOME}/.claude/tools/ctx-monitor/ctx-monitor.py"
  mkdir -p "$CTX_DIR"
  monitor_alive=0
  if [ -f "$CTX_DIR/monitor.lock" ]; then
    lock_pid="$(cat "$CTX_DIR/monitor.lock" 2>/dev/null | tr -dc '0-9')"
    if [ -n "$lock_pid" ] && kill -0 "$lock_pid" 2>/dev/null; then
      monitor_alive=1
    fi
  fi
  if [ "$monitor_alive" -eq 0 ] && [ -f "$MON" ]; then
    SYS_PY="$(command -v python3 || true)"
    if [ -n "$SYS_PY" ]; then
      if command -v setsid >/dev/null 2>&1; then
        setsid "$SYS_PY" "$MON" >> "$CTX_DIR/monitor.out" 2>&1 < /dev/null &
      else
        nohup "$SYS_PY" "$MON" >> "$CTX_DIR/monitor.out" 2>&1 < /dev/null &
        disown
      fi
    fi
  fi
} || true

# Run from this dir so `python -m agents_tui` resolves the package regardless
# of the caller's cwd (PYTHONPATH also set as a belt-and-braces fallback).
export PYTHONPATH="${HERE}${PYTHONPATH:+:$PYTHONPATH}"
cd "$HERE"
exec "$VENV_PY" -m agents_tui "$@"
